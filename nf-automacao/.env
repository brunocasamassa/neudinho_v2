# ============ TELEGRAM ============
# Token do bot — crie com @BotFather no Telegram e cole aqui.
TELEGRAM_TOKEN=8832141457:AAEWgPKvXCbrtgncgj5vwslmzL0_eTdftL0

# Chat id de quem aprova/recebe avisos (o Neuds).
# Para descobrir: rode o app, mande /start pro bot, ele responde com o seu chat id.
TELEGRAM_APPROVER_CHAT_ID=

# ============ DMS (MicroWork CLOUD) ============
# URL de ENTRADA do app (gera token de login novo a cada acesso).
# NAO use a URL com ?signin=... (token de uso unico que expira em segundos).
DMS_ENTRY_URL=https://www.microworkcloud.com.br
DMS_USER=felipe@feltrinmotos.com.br
DMS_PASS=Felipebe@003@003
# (opcional) caminho do chrome.exe; vazio = autodetecta Chrome/Edge instalado.
DMS_CHROME_PATH=
# Perfil dedicado do Chrome do bot (guarda login + clearance do Cloudflare).
DMS_CHROME_PROFILE=.chrome-dms
DMS_CDP_PORT=9222
DMS_NAV_TIMEOUT_MS=60000
# Trava de seguranca: deixe false ate confiar; true = grava a nota de verdade.
DMS_CONFIRM_SAVE=false

# ============ IA (opcional) ============
# USE_AI=false -> usa so a extracao por regex (perfeito pra testar local sem custo).
# USE_AI=true  -> chama a API da Anthropic pra validar/estruturar os campos.
USE_AI=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ============ FLUXO ============
# Pedir aprovacao no Telegram antes de lancar no DMS?
REQUIRE_APPROVAL=true
# Mostrar o navegador do Playwright (true) ou rodar invisivel (false)?
PLAYWRIGHT_HEADED=true

# ============ WEBHOOK (so na VPS) ============
# Usado pelo "npm run webhook". No localhost use "npm start" (polling) e ignore isto.
WEBHOOK_URL=
WEBHOOK_PORT=8080
WEBHOOK_PATH=/telegram
